# GitHub token. Prefer a fine-grained PAT scoped to the repos you want this
# server to touch (Settings > Developer settings > Personal access tokens):
#   - Pull requests: Read and write
#   - Contents:      Read-only
#   - Metadata:      Read-only (required)
# Classic `repo`-scoped tokens also work; fine-grained is just narrower in scope 
# and better security practice.
GITHUB_TOKEN=ghp_replace_me

# Default owner/repo when a tool call omits them. Also seeds the allowlists
# below if those are unset.
GITHUB_OWNER=SalixDev
GITHUB_REPO=my-repo-name

# Read allowlist. Comma-separated `owner/repo`, or `*` for any repo your token
# can reach. Unset → defaults to `${GITHUB_OWNER}/${GITHUB_REPO}` (or `*` if
# those aren't set). Example: SalixDev/repo-a,SalixDev/repo-b
GITHUB_ALLOWED_REPOS=

# Write allowlist for add_pr_comment / add_pr_review_comment. Same syntax.
# Unset → defaults to the read allowlist.
GITHUB_WRITE_ALLOWED_REPOS=
